#!/usr/bin/env bash

set -euo pipefail

changed_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if ! grep -Eq '^presentation/(index\.html|styles\.css|assets/)' <<<"$changed_files"; then
  exit 0
fi

echo "Regenerating presentation PDF..."
python presentation/export_pdf.py
git add presentation/presentation.pdf
